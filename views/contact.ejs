<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body class="min-h-screen flex flex-col bg-gray-900 text-gray-100">
  <%- include('partials/navbar') %>

  <main class="flex-grow p-4">
    <!-- Hero Section -->
    <div class="relative mb-6">
      <!-- Removing the purple gradient overlay -->
      <img src="https://images.pexels.com/photos/821754/pexels-photo-821754.jpeg?auto=compress&cs=tinysrgb&w=1600" alt="Contact Us Featured" class="w-full h-80 object-cover object-center rounded-xl">

    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
      <!-- Contact Form -->
      <div class="lg:col-span-2">
        <div class="bg-gray-800 rounded-xl shadow-lg p-8 border border-gray-700 h-full">
          <h2 class="text-2xl font-bold text-white mb-6">Send Us a Message</h2>
          <form action="/contact" method="POST">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-300 mb-2">Your Name</label>
                <input type="text" id="name" name="name" placeholder="John Doe" class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-gray-100 placeholder-gray-400 focus:ring focus:ring-indigo-500 focus:border-indigo-500">
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-300 mb-2">Your Email</label>
                <input type="email" id="email" name="email" placeholder="your@email.com" class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-gray-100 placeholder-gray-400 focus:ring focus:ring-indigo-500 focus:border-indigo-500">
              </div>
            </div>
            

            
            <div class="mb-6">
              <label for="message" class="block text-sm font-medium text-gray-300 mb-2">Your Message</label>
              <textarea id="message" name="message" rows="6" placeholder="Type your message here..." class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-gray-100 placeholder-gray-400 focus:ring focus:ring-indigo-500 focus:border-indigo-500"></textarea>
            </div>
            
            <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-3 px-6 rounded-lg transition duration-300 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              Send Message
            </button>
          </form>
        </div>
      </div>
      
      <!-- Contact Information -->
      <div>
        <div class="bg-gray-800 rounded-xl shadow-lg p-8 border border-gray-700 mb-6">
          <h2 class="text-xl font-bold text-white mb-4">Contact Information</h2>
          <div class="space-y-4">
            <div class="flex items-start">
              <div class="bg-indigo-700 p-2 rounded-lg mr-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-gray-400">Email</p>
                <a href="mailto:support@hotellink.com" class="text-indigo-400 hover:text-indigo-300">support@hotellink.com</a>
              </div>
            </div>
            <div class="flex items-start">
              <div class="bg-indigo-700 p-2 rounded-lg mr-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-gray-400">Phone</p>
                <a href="tel:+18005551234" class="text-indigo-400 hover:text-indigo-300">+91 1234567890</a>
              </div>
            </div>
            <div class="flex items-start">
              <div class="bg-indigo-700 p-2 rounded-lg mr-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-gray-400">Address</p>
                <p class="text-indigo-400">123 Booking Street<br>Punjab, Rajpura<br>India</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Office Hours -->
        <div class="bg-gray-800 rounded-xl shadow-lg p-8 border border-gray-700">
          <h2 class="text-xl font-bold text-white mb-4">Office Hours</h2>
          <div class="space-y-2">
            <div class="flex justify-between">
              <span class="text-gray-400">Monday - Friday:</span>
              <span class="text-white">9:00 AM - 6:00 PM</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-400">Saturday:</span>
              <span class="text-white">10:00 AM - 4:00 PM</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-400">Sunday:</span>
              <span class="text-white">Closed</span>
            </div>
            <div class="mt-4 pt-4 border-t border-gray-700">
              <span class="text-indigo-400">24/7 Customer Support Available</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Map Section -->
    <div class="bg-gray-800 rounded-xl shadow-lg p-8 border border-gray-700 mb-8">
      <h2 class="text-2xl font-bold text-white mb-6">Find Us</h2>
      <div class="rounded-xl overflow-hidden h-96 bg-gray-700">
        <!-- Google Maps iframe - Updated to the correct Chitkara University location -->
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3437.174971800065!2d76.6572028762075!3d30.51609109606944!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x390fc32344a6e2d7%3A0x81b346dee91799ca!2sChitkara%20University!5e0!3m2!1sen!2sin!4v1746763035995!5m2!1sen!2sin" 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
          class="rounded-xl"
          title="Hotel Link Location - Chitkara University, Punjab">
        </iframe>
      </div>
    </div>
    
    <!-- FAQ Section -->
    <div class="bg-gray-800 rounded-xl shadow-lg p-8 mb-8 border border-gray-700">
      <h2 class="text-2xl font-bold text-white text-center mb-8">Frequently Asked Questions</h2>
      <div class="max-w-3xl mx-auto space-y-4">
        <div class="bg-gray-700 p-6 rounded-xl shadow-md">
          <h3 class="text-lg font-semibold text-white mb-2">How do I cancel or modify a booking?</h3>
          <p class="text-gray-300">You can manage your bookings by logging into your account and navigating to the "Dashboard" section. From there, you can cancel or modify your reservation according to the property's policy.</p>
        </div>
        <div class="bg-gray-700 p-6 rounded-xl shadow-md">
          <h3 class="text-lg font-semibold text-white mb-2">When will I be charged for my booking?</h3>
          <p class="text-gray-300">Payment policies vary by property. Some require full payment at the time of booking, while others allow payment upon arrival. The specific policy will be clearly displayed during the booking process.</p>
        </div>
        <div class="bg-gray-700 p-6 rounded-xl shadow-md">
          <h3 class="text-lg font-semibold text-white mb-2">Is my payment information secure?</h3>
          <p class="text-gray-300">Yes, we use industry-standard encryption and security protocols to protect your personal and payment information. Your data is never shared with third parties without your explicit consent.</p>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script>
    // Dark mode toggle functionality
    document.addEventListener('DOMContentLoaded', function() {
      const darkModeToggle = document.querySelector('.dark-mode-toggle');
      if (darkModeToggle) {
        darkModeToggle.addEventListener('click', function() {
          // Toggle between dark/light mode if you want to implement this
          alert('This site is already in dark mode by default!');
        });
      }
    });
  </script>
</body>
</html>