<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body class="min-h-screen flex flex-col bg-gray-900 text-gray-100">
    <%- include('partials/navbar') %>
    <main class="flex-grow p-4 flex items-center justify-center">
      <div class="w-full max-w-md">
        <div class="bg-gray-800 rounded-xl shadow-lg overflow-hidden border border-gray-700">
          <div class="bg-gradient-to-r from-green-700 to-green-500 p-6 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-12 w-12 text-green-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2l4-4m6 2a9 9 0 11-18 0a9 9 0 0118 0z" />
            </svg>
            <h1 class="text-2xl font-bold text-white">Password Reset Successful</h1>
            <p class="text-green-200 mt-2">Your password has been changed successfully. You can now log in with your new password.</p>
          </div>
          <div class="p-6 text-center">
            <a href="/login" class="inline-block bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-6 rounded transition duration-300 mt-4">
              Go to Login
            </a>
          </div>
        </div>
      </div>
    </main>
    <%- include('partials/footer') %>
  </body>
</html>
