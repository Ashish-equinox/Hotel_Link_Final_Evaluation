<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body class="min-h-screen flex flex-col bg-gray-900 text-gray-100">
  <%- include('partials/navbar') %>

  <main class="flex-grow p-4 flex items-center justify-center">
    <div class="w-full max-w-md">
      <div class="bg-gray-800 rounded-xl shadow-lg overflow-hidden border border-gray-700">
        <!-- Signup Header -->
        <div class="bg-gradient-to-r from-indigo-800 to-purple-800 p-6 text-center">
          <div class="mb-4 flex justify-center">
            <div class="bg-indigo-700 p-3 rounded-full inline-flex items-center">
            </div>
          </div>
          <h1 class="text-2xl font-bold text-white">Create Your Account</h1>
          <p class="text-indigo-200 mt-2">Join Hotel Link to start exploring exceptional stays</p>
        </div>
        
        <!-- Signup Form -->
        <div class="p-6">
          <form action="/signup" method="POST" class="max-w-md mx-auto bg-gray-800 p-6 rounded-lg">
            <div class="mb-4">
              <label for="firstName" class="block text-sm text-gray-400 mb-2">First Name</label>
              <input type="text" id="firstName" name="firstName" class="w-full p-2 rounded bg-gray-700 text-white" required>
            </div>
            <div class="mb-4">
              <label for="lastName" class="block text-sm text-gray-400 mb-2">Last Name</label>
              <input type="text" id="lastName" name="lastName" class="w-full p-2 rounded bg-gray-700 text-white" required>
            </div>
            <div class="mb-4">
              <label for="email" class="block text-sm text-gray-400 mb-2">Email</label>
              <input type="email" id="email" name="email" class="w-full p-2 rounded bg-gray-700 text-white" required>
            </div>
            <div class="mb-4">
              <label for="password" class="block text-sm text-gray-400 mb-2">Password</label>
              <input type="password" id="password" name="password" class="w-full p-2 rounded bg-gray-700 text-white" required>
            </div>
            <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white py-2 rounded">
              Sign Up
            </button>
          </form>
          
          <div class="mt-6 pt-6 border-t border-gray-700 text-center">
            <p class="text-gray-400">Already have an account?</p>
            <a href="/login" class="block mt-2 bg-gray-700 hover:bg-gray-600 text-white font-medium py-3 px-4 rounded-lg transition duration-300">Log In</a>
          </div>
        </div>
      </div>
      
      <!-- Social Signup -->
      <div class="mt-6">
        <div class="relative">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-700"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-2 bg-gray-900 text-gray-400">Or sign up with</span>
          </div>
        </div>
        
        <div class="mt-6 grid grid-cols-3 gap-3">
          <a href="https:/google.com" class="w-full flex items-center justify-center py-2 px-4 border border-gray-700 rounded-md shadow-sm bg-gray-800 hover:bg-gray-700 transition duration-300">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.5 12.5c0-5.799-4.701-10.5-10.5-10.5S1.5 6.701 1.5 12.5c0 5.799 4.701 10.5 10.5 10.5 5.799 0 10.5-4.701 10.5-10.5z" stroke="#4285F4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
              <path d="M12 7.5v10M7 12.5h10" stroke="#EA4335" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </a>
          
          <a href="https:/facebook.com" class="w-full flex items-center justify-center py-2 px-4 border border-gray-700 rounded-md shadow-sm bg-gray-800 hover:bg-gray-700 transition duration-300">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3V2z" stroke="#3B5998" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </a>
          
          <a href="https:/apple.com" class="w-full flex items-center justify-center py-2 px-4 border border-gray-700 rounded-md shadow-sm bg-gray-800 hover:bg-gray-700 transition duration-300">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12.146 2c.2 1.4-.3 2.8-1 3.8-.7 1-1.9 1.7-3 1.7-.2-1.3.3-2.7 1-3.7.8-1.1 2-1.8 3-1.8zM15.4 21.5c.9 0 1.4-.6 2.3-1.5 1-.9 1.4-2.1 1.4-3.4 0-1.2-.5-2.3-1.6-3 .1-.9.8-2.5 2.8-4-1.4-1.9-2.8-2.1-3.3-2.1-1.4 0-2.3.7-3 .7-.7 0-1.7-.7-3-.7-2.4 0-4.9 2-4.9 5.7 0 2.2.7 4.6 1.6 6.2 1 1.4 1.8 2.1 2.9 2.1 1 0 1.6-.7 3-.7 1.3 0 1.8.7 2.8.7z" stroke="#000" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </a>
        </div>
      </div>
      
      <!-- Marketing Opt-in -->

    </div>
  </main>


  
  <%- include('partials/footer') %>

  <script>
    // Password validation functionality
    document.addEventListener('DOMContentLoaded', function() {
      const password = document.getElementById('password');
      const confirmPassword = document.getElementById('confirmPassword');
      const form = document.querySelector('form');
      
      if (form && password && confirmPassword) {
        form.addEventListener('submit', function(event) {
          if (password.value !== confirmPassword.value) {
            event.preventDefault();
            alert('Passwords do not match. Please try again.');
            confirmPassword.focus();
          }
        });
      }
      
      // Dark mode toggle functionality
      const darkModeToggle = document.querySelector('.dark-mode-toggle');
      if (darkModeToggle) {
        darkModeToggle.addEventListener('click', function() {
          // Toggle between dark/light mode if you want to implement this
          alert('This site is already in dark mode by default!');
        });
      }
    });
  </script>
</body>
</html>